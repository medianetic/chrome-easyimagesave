{
  "manifest_version": 3,
  "name": "EasyImageSave",
  "version": "1.0.0",
  "description": "Save images in JPG, PNG, or WEBP format easily.",
  "permissions": [
    "contextMenus",
    "downloads",
    "activeTab",
    "offscreen",
    "notifications"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background/background.ts",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/index.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/content.ts"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/background/offscreen.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}
