{
  "manifest_version": 3,
  "name": "EasyImageSave",
  "version": "1.0.0",
  "description": "Save images in JPG, PNG, or WEBP format easily.",
  "permissions": [
    "contextMenus",
    "downloads",
    "activeTab",
    "offscreen",
    "notifications",
    "clipboardWrite"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/index.html"
  },
  "content_scripts": [
    {
      "js": [
        "assets/content.ts-DmW90NP4.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "src/background/offscreen.html",
        "assets/content.ts-DmW90NP4.js"
      ],
      "use_dynamic_url": false
    }
  ],
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}
